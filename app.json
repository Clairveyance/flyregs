{
  "expo": {
    "name": "FlyRegs",
    "slug": "ac-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flyregs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.clairveyance.flyregs",
      "supportsTablet": true,
      "ITSAppUsesNonExemptEncryption": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      }
    },
    "android": {
      "package": "com.clairveyance.flyregs",
      "adaptiveIcon": {
        "backgroundColor": "#07111E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07111E",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#C6A224",
          "mode": "production"
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "FlyRegs uses your photo library to set a profile picture, shown when you share content with other users.",
          "cameraPermission": "FlyRegs uses your camera to take a profile picture, shown when you share content with other users.",
          "microphonePermission": false
        }
      ],
      "expo-file-system",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3c43ad1e-f244-4270-b088-8db775b0dbe7"
      }
    },
    "owner": "clairveyance"
  }
}
